# Per-service roles for IRSA (IAM Roles for Service Accounts)
# Each service gets only the AWS permissions it needs

resource "aws_iam_role" "order_service" {
  name = "${var.name_prefix}-order-service-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Action = "sts:AssumeRole"
      Effect = "Allow"
      Principal = { Service = "ec2.amazonaws.com" }
    }]
  })
}

resource "aws_iam_policy" "order_service" {
  name = "${var.name_prefix}-order-service-policy"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Action   = ["rds-db:connect"]
        Resource = "*"
      },
      {
        Effect   = "Allow"
        Action   = ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "order_service" {
  policy_arn = aws_iam_policy.order_service.arn
  role       = aws_iam_role.order_service.name
}

resource "aws_iam_role" "notification_service" {
  name = "${var.name_prefix}-notification-service-role"

  assume_role_policy = jsonencode({
    Version = "2012-10-17"
    Statement = [{
      Action = "sts:AssumeRole"
      Effect = "Allow"
      Principal = { Service = "ec2.amazonaws.com" }
    }]
  })
}

resource "aws_iam_policy" "notification_service" {
  name = "${var.name_prefix}-notification-service-policy"

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Effect   = "Allow"
        Action   = ["cassandra:Select", "cassandra:Modify"]
        Resource = "*"
      },
      {
        Effect   = "Allow"
        Action   = ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"]
        Resource = "*"
      }
    ]
  })
}

resource "aws_iam_role_policy_attachment" "notification_service" {
  policy_arn = aws_iam_policy.notification_service.arn
  role       = aws_iam_role.notification_service.name
}
