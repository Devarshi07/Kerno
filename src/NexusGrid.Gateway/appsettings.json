{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "NexusGrid-Super-Secret-Key-For-Development-Only-Min-32-Chars!",
    "Issuer": "NexusGrid.UserService",
    "Audience": "NexusGrid"
  },
  "RateLimit": {
    "WindowSeconds": 60,
    "MaxRequests": 100
  },
  "Cache": {
    "DefaultTtlSeconds": 30,
    "CacheablePaths": ["/api/v1/orders"]
  },
  "ReverseProxy": {
    "Routes": {
      "orders-route": {
        "ClusterId": "order-service",
        "Match": {
          "Path": "/api/v1/orders/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "auth-route": {
        "ClusterId": "user-service",
        "Match": {
          "Path": "/api/v1/auth/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "users-route": {
        "ClusterId": "user-service",
        "Match": {
          "Path": "/api/v1/users/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "notifications-route": {
        "ClusterId": "notification-service",
        "Match": {
          "Path": "/api/v1/notifications/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      },
      "audit-route": {
        "ClusterId": "notification-service",
        "Match": {
          "Path": "/api/v1/audit/{**catch-all}"
        },
        "Transforms": [
          { "RequestHeaderOriginalHost": "true" }
        ]
      }
    },
    "Clusters": {
      "order-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5101/"
          }
        }
      },
      "user-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5102/"
          }
        }
      },
      "notification-service": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5103/"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Yarp": "Information"
      }
    }
  }
}
